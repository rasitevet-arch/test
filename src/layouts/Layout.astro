---
import "@/styles/global.css";
import { Seo } from "astro-seo-meta";
import { Schema } from "astro-seo-schema";
import type { SeoData } from "@/content/config";

const SITE_NAME = "Main Insurance";
const SITE_URL = import.meta.env.SITE ?? "https://maininsurance.gr";

interface Props {
  title?: string;
  description?: string;
  seo?: SeoData;
}

const { title, description, seo } = Astro.props;

const locale = Astro.currentLocale ?? "en";
const pageTitle = seo?.title ?? title ?? SITE_NAME;
const metaTitle = pageTitle.includes(SITE_NAME) ? pageTitle : `${pageTitle} | ${SITE_NAME}`;
const metaDescription = seo?.description ?? description ?? "";
const ogImage = seo?.image
  ? new URL(seo.image, SITE_URL).href
  : `${SITE_URL}/assets/img/og-default.jpg`;
const canonicalUrl = seo?.canonical ?? new URL(Astro.url.pathname, SITE_URL).href;
const keywords = seo?.keywords ?? [];
const robots = seo?.robots ?? "index, follow";
const twitterCard = seo?.twitterCard ?? "summary_large_image";
const twitterSite = seo?.twitterSite;
const twitterCreator = seo?.twitterCreator;
const ogType = seo?.ogType ?? "website";
const ogSiteName = seo?.ogSiteName ?? SITE_NAME;
const ogLocale = seo?.ogLocale ?? (locale === "el" ? "el_GR" : "en_US");
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robots} />

    <Seo
      title={metaTitle}
      description={metaDescription}
      keywords={keywords}
      icon="/favicon.ico"
      colorScheme="dark"
      robots={robots}
      facebook={{
        image: ogImage,
        url: canonicalUrl,
        type: ogType,
      }}
      twitter={{
        image: ogImage,
        card: twitterCard,
        site: twitterSite,
      }}
    />

    {/* Extra OG tags not covered by astro-seo-meta */}
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:locale" content={ogLocale} />
    {twitterCreator && <meta name="twitter:creator" content={twitterCreator} />}

    <Schema
      item={{
        "@context": "https://schema.org",
        "@type": "InsuranceAgency",
        name: SITE_NAME,
        url: SITE_URL,
        description: metaDescription,
        image: ogImage,
        address: {
          "@type": "PostalAddress",
          addressLocality: "Athens",
          addressCountry: "GR",
        },
      }}
    />
  </head>
  <body class="relative">
    <div class="page-wrapper relative">
      <slot />
    </div>
  </body>
</html>
