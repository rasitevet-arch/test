---
interface Props {
  title?: string;
  paragraphs?: string[];
  buttonLink?: string;
  buttonLabel?: string;
  image?: { src: string; alt: string; width: number; height: number };
}

const {
  title = "Lorem Ipsum Dolor Sit Amet Consectetur",
  paragraphs = [
    "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.",
    "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.",
  ],
  buttonLink = "#",
  buttonLabel = "Learn More",
  image = { src: "https://placehold.co/600x400", alt: "Feature image", width: 600, height: 400 },
} = Astro.props;
---

<section class="section-content">
  <div class="bg-">
    <div class="section-space">
      <div class="container">
        <div class="grid grid-cols-1 gap-y-20 lg:gap-y-[100px] xl:gap-y-[130px]">
          <div class="grid grid-cols-1 items-center gap-10 md:gap-[60px] lg:grid-cols-2 xl:grid-cols-[1fr_minmax(0,0.8fr)] xl:gap-20">
            <div class="relative z-10 order-2 mx-auto inline-flex max-w-[500px] items-center justify-center lg:max-w-full">
              <img src={image.src} alt={image.alt} width={image.width} height={image.height} class="max-w-full" />
            </div>
            <div class="order-1">
              <div class="mb-[50px]">
                <h2>{title}</h2>
              </div>
              <div>
                <div class="mt-5">
                  {paragraphs.map((p) => <p>{p}</p>)}
                </div>
                <a href={buttonLink} class="btn btn-primary mt-[50px]">
                  <span>{buttonLabel}</span>
                  <span>{buttonLabel}</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
