---
import { Icon } from "astro-icon/components";

interface Props {
  testimonials?: { quote: string; name: string; rating: number; avatar: string }[];
}

const {
  testimonials = [
    {
      quote:
        "Consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
      name: "John Doe",
      rating: 5,
      avatar: "https://placehold.co/55x55",
    },
    {
      quote:
        "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo.",
      name: "Jane Smith",
      rating: 5,
      avatar: "https://placehold.co/55x55",
    },
    {
      quote:
        "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla.",
      name: "Bob Wilson",
      rating: 4,
      avatar: "https://placehold.co/55x55",
    },
  ],
} = Astro.props;
---

<section class="section-testimonial" id="testimonial">
  <div class="section-space">
    <div>
      <div class="testimonial-slider swiper">
        <div class="swiper-wrapper">
          {testimonials.map((t) => {
            const stars = Math.ceil(t.rating);
            return (
              <div class="swiper-slide">
                <div class="rounded-md border border-[#DBDBDB] p-9">
                  <div class="inline-flex gap-x-1">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <Icon
                        name="lets-icons:star-fill"
                        class={`h-6 w-6 ${i < stars ? "text-amber-400" : "text-gray-300"}`}
                      />
                    ))}
                  </div>
                  <blockquote class="my-5 text-txt-secondary">{t.quote}</blockquote>
                  <div class="flex items-center gap-2.5">
                    {t.avatar && (
                      <div class="h-14 w-14 overflow-hidden rounded-full bg-gray-200">
                        <img src={t.avatar} alt={t.name} width={55} height={55} class="h-full w-full object-cover" loading="lazy" referrerpolicy="no-referrer" />
                      </div>
                    )}
                    <span class="block font-bold text-txt-secondary">{t.name}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
      <div class="testimonial-slider-reverse swiper mt-10">
        <div class="swiper-wrapper">
          {testimonials.map((t) => {
            const stars = Math.ceil(t.rating);
            return (
              <div class="swiper-slide">
                <div class="rounded-md border border-[#DBDBDB] p-9">
                  <div class="inline-flex gap-x-1">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <Icon
                        name="lets-icons:star-fill"
                        class={`h-6 w-6 ${i < stars ? "text-amber-400" : "text-gray-300"}`}
                      />
                    ))}
                  </div>
                  <blockquote class="my-5 text-txt-secondary">{t.quote}</blockquote>
                  <div class="flex items-center gap-2.5">
                    {t.avatar && (
                      <div class="h-14 w-14 overflow-hidden rounded-full bg-gray-200">
                        <img src={t.avatar} alt={t.name} width={55} height={55} class="h-full w-full object-cover" loading="lazy" referrerpolicy="no-referrer" />
                      </div>
                    )}
                    <span class="block font-bold text-txt-secondary">{t.name}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>

<script src="@/scripts/swiper.ts"></script>
