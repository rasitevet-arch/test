---
interface Props {
  mapSrc?: string;
}

const {
  mapSrc = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3145.3272897828437!2d23.7275!3d37.9838!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzfCsDU5JzAxLjciTiAyM8KwNDMnMzkuMCJF!5e0!3m2!1sen!2sgr!4v1234567890",
} = Astro.props;
---

<div class="sction-map">
  <div>
    <div class="h-96 w-full overflow-hidden lg:h-[600px]">
      <iframe class="h-full w-full" src={mapSrc}></iframe>
    </div>
  </div>
</div>
