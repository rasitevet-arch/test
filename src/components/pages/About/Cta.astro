---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import bgShape1 from "@/assets/images/shared/background-shape-1.svg";
import iconUnion from "@/assets/images/shared/icon-union.svg";

interface Props {
  title?: string;
  buttonLink?: string;
}

const { title = "Lorem Ipsum Dolor Sit Amet Consectetur Adipiscing", buttonLink = "#" } =
  Astro.props;

const isSensitive = buttonLink.startsWith("tel:") || buttonLink.startsWith("mailto:");
const obfuscated = isSensitive ? btoa(buttonLink) : null;
---

<section class="section-cta">
  <div class="section-space relative">
    <div class="container">
      <div class="flex flex-wrap items-center justify-center gap-10 sm:flex-nowrap sm:justify-between">
        <div class="sm:max-w-[820px] sm:flex-1">
          <h2>
            {title}
            <Image
              src={iconUnion}
              alt="icon-union"
              width={83}
              height={80}
              class="inline h-auto w-10 lg:w-16"
            />
          </h2>
        </div>
        <a
          href={obfuscated ? "#" : buttonLink}
          data-ob={obfuscated}
          class="group relative inline-flex h-20 w-20 items-center justify-center overflow-hidden rounded-full bg-accent lg:h-[100px] lg:w-[100px] xl:h-[120px] xl:w-[120px] js-ob-link"
        >
          <span
            class="transition-default translate-x-0 translate-y-0 text-white group-hover:-translate-y-full group-hover:translate-x-full"
          >
            <Icon name="lets-icons:external" class="h-12 w-12 lg:h-14 lg:w-14 xl:h-16 xl:w-16" />
          </span>
          <span
            class="transition-default absolute -translate-x-full translate-y-full text-white group-hover:translate-x-0 group-hover:translate-y-0"
          >
            <Icon name="lets-icons:external" class="h-12 w-12 lg:h-14 lg:w-14 xl:h-16 xl:w-16" />
          </span>
        </a>
      </div>
    </div>
    <Image
      src={bgShape1}
      alt="background-shape-1"
      width={273}
      height={204}
      class="absolute left-5 top-1 -z-10 hidden xxxl:inline-block"
    />
  </div>
  <div class="mx-auto h-px w-full max-w-full bg-border px-5 sm:max-w-[540px] md:max-w-[720px] lg:max-w-[960px] xl:max-w-[1140px] xxl:max-w-[1330px]">
  </div>
</section>

<script>
  document.querySelectorAll<HTMLAnchorElement>("a.js-ob-link[data-ob]").forEach((el) => {
    const encoded = el.dataset.ob;
    if (!encoded) return;
    setTimeout(() => {
      el.href = atob(encoded);
      delete el.dataset.ob;
    }, 500);
  });
</script>
