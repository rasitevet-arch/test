---
import BlockRenderer from "@components/BlockRenderer.astro";
import Breadcrumb from "@components/global/Breadcrumb.astro";
import Footer from "@components/global/Footer.astro";
import Header from "@components/global/Header.astro";
import Layout from "@layouts/Layout.astro";
import { getPageData } from "@/lib/cms";
import type { Locale } from "@/types/cms";

const locale = (Astro.currentLocale ?? "en") as Locale;
const page = await getPageData("about", locale);
if (!page) return Astro.redirect("/error-404");
---

<Layout title={page.title} description={page.description} seo={page.seo}>
  <Header isLanding={page.isLanding} />

  <main class="main-wrapper relative overflow-x-clip">
    {!page.isLanding && page.breadcrumbTitle && (
      <Breadcrumb
        title={page.breadcrumbTitle}
        path={page.breadcrumbPath}
        current={page.breadcrumbCurrent ?? ""}
      />
    )}

    <BlockRenderer blocks={page.blocks} />
  </main>

  <Footer isLanding={page.isLanding} />
</Layout>
