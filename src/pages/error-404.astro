---
import Footer from "@components/global/Footer.astro";
import Header from "@components/global/Header.astro";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Sofax | SASS & Startup Tailwind Template">
  <Header />

  <main class="main-wrapper relative overflow-x-clip">
    <div class="section-404">
      <div class="section-space pt-24 md:pt-32 lg:pt-40 xl:pt-52">
        <div class="container">
          <div class="mx-auto max-w-3xl text-center xl:max-w-4xl">
            <img
              src="/assets/img/images/home-1/404.svg"
              alt="404.svg"
              width="629"
              height="270"
              class="mx-auto"
            />
            <h2 class="mb-10 mt-10 md:mt-[60px] lg:mt-20">
              Oops! Looks like you took a wrong turn
            </h2>
            <a href="/" class="btn btn-primary">
              <span>Back To Home</span>
              <span>Back To Home</span>
            </a>
          </div>
        </div>
      </div>

      <div
        class="mx-auto h-px w-full max-w-full bg-border px-5 sm:max-w-[540px] md:max-w-[720px] lg:max-w-[960px] xl:max-w-[1140px] xxl:max-w-[1330px]"
      ></div>
    </div>

    <section class="section-cta">
      <div class="section-space relative">
        <div class="container">
          <div
            class="flex flex-wrap items-center justify-center gap-10 sm:flex-nowrap sm:justify-between"
          >
            <div class="sm:max-w-[820px] sm:flex-1">
              <h2>
                Let's embark on a digital journey together!
                <img
                  src="/assets/img/images/home-5/icon-union.svg"
                  alt="icon-union"
                  width="83"
                  height="80"
                  class="inline h-auto w-10 lg:w-16"
                />
              </h2>
            </div>

            <a
              href="/contact"
              class="group relative inline-flex h-20 w-20 items-center justify-center overflow-hidden rounded-full bg-accent lg:h-[100px] lg:w-[100px] xl:h-[120px] xl:w-[120px]"
            >
              <span
                class="transition-default translate-x-0 translate-y-0 text-white group-hover:-translate-y-full group-hover:translate-x-full"
              >
                <Icon name="lets-icons:external" class="h-12 w-12 lg:h-14 lg:w-14 xl:h-16 xl:w-16" />
              </span>
              <span
                class="transition-default absolute -translate-x-full translate-y-full text-white group-hover:translate-x-0 group-hover:translate-y-0"
              >
                <Icon name="lets-icons:external" class="h-12 w-12 lg:h-14 lg:w-14 xl:h-16 xl:w-16" />
              </span>
            </a>
          </div>
        </div>

        <img
          src="/assets/img/images/home-5/background-shape-1.svg"
          alt="background-shape-1"
          width="273"
          height="204"
          class="absolute left-5 top-1 -z-10 hidden xxxl:inline-block"
        />
      </div>

      <div
        class="mx-auto h-px w-full max-w-full bg-border px-5 sm:max-w-[540px] md:max-w-[720px] lg:max-w-[960px] xl:max-w-[1140px] xxl:max-w-[1330px]"
      ></div>
    </section>
  </main>

  <Footer />
</Layout>
